#:kivy 2.0

<BusTicketScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.957, 0.961, 0.980, 1

        MDTopAppBar:
            title: "Bus Ticket"
            left_action_items: [["arrow-left", lambda x: root.go_back()]]
            md_bg_color: 0.17, 0.75, 0.67, 1
            specific_text_color: 1, 1, 1, 1

        MDBoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(16)

            MDLabel:
                text: "Bus Ticket Screen"
                halign: "center"
                theme_text_color: "Secondary"
                font_style: "H6"
