#:kivy 2.0

<DailyPassScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 1, 1, 1, 1

        # ── TOP BAR ───────────────────────────────────────────────
        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(56)
            md_bg_color: 1, 1, 1, 1
            padding: dp(8), 0, dp(16), 0
            spacing: dp(4)

            MDIconButton:
                icon: "arrow-left"
                theme_icon_color: "Custom"
                icon_color: 0.1, 0.1, 0.1, 1
                icon_size: dp(26)
                pos_hint: {"center_y": 0.5}
                on_release: root.go_back()

            MDLabel:
                text: "Daily Pass"
                theme_text_color: "Custom"
                text_color: 0.1, 0.1, 0.1, 1
                bold: True
                font_size: dp(20)
                valign: "center"

            MDLabel:
                text: root.timer_text
                theme_text_color: "Custom"
                text_color: 0.3, 0.3, 0.3, 1
                font_size: dp(20)
                halign: "right"
                valign: "center"
                size_hint_x: None
                width: dp(70)

        MDBoxLayout:
            size_hint_y: None
            height: dp(1)
            md_bg_color: 0.93, 0.93, 0.93, 1

        # ── BODY ──────────────────────────────────────────────────
        ScrollView:
            do_scroll_x: False
            bar_width: 0

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                padding: dp(16), dp(16), dp(16), dp(16)
                spacing: dp(16)

                # ── PASS TICKET CARD ──────────────────────────────
                MDCard:
                    orientation: "vertical"
                    md_bg_color: 0.965, 0.965, 0.965, 1
                    radius: [dp(14)]
                    elevation: 0
                    line_color: 0.88, 0.88, 0.88, 1
                    line_width: 1
                    size_hint_y: None
                    height: self.minimum_height
                    padding: 0
                    spacing: 0

                    # Green header strip
                    MDCard:
                        md_bg_color: 0.13, 0.6, 0.3, 1
                        radius: [dp(14), dp(14), 0, 0]
                        elevation: 0
                        size_hint_y: None
                        height: dp(52)
                        padding: dp(20), 0, dp(20), 0

                        MDLabel:
                            text: root.date_text
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            bold: True
                            font_size: dp(17)
                            valign: "center"

                    # Select pass type
                    MDLabel:
                        text: "Select pass type"
                        theme_text_color: "Custom"
                        text_color: 0.15, 0.15, 0.15, 1
                        font_size: dp(20)
                        size_hint_y: None
                        height: dp(74)
                        padding_x: dp(20)
                        valign: "center"

                    # ── PERFORATION ───────────────────────────────
                    Widget:
                        size_hint_y: None
                        height: dp(24)
                        canvas.after:
                            Color:
                                rgba: 1, 1, 1, 1
                            Ellipse:
                                pos: self.x - dp(12), self.center_y - dp(12)
                                size: dp(24), dp(24)
                            Ellipse:
                                pos: self.right - dp(12), self.center_y - dp(12)
                                size: dp(24), dp(24)
                            Color:
                                rgba: 0.7, 0.7, 0.7, 1
                            Line:
                                points: self.x + dp(16), self.center_y, self.right - dp(16), self.center_y
                                dash_length: dp(6)
                                dash_offset: dp(4)
                                width: 1

                    # ── AADHAR / PAN ──────────────────────────────
                    MDBoxLayout:
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_height
                        padding: dp(20), dp(12), dp(20), dp(20)
                        spacing: dp(16)

                        MDLabel:
                            text: "Enter last 4 digits of your\nAadhar Card or Pan Card"
                            theme_text_color: "Custom"
                            text_color: 0.2, 0.2, 0.2, 1
                            font_size: dp(19)
                            line_height: 1.2
                            size_hint_y: None
                            height: dp(60)
                            valign: "center"

                        MDCard:
                            md_bg_color: 1, 1, 1, 1
                            line_color: 0.85, 0.85, 0.85, 1
                            line_width: 1
                            radius: [dp(8)]
                            elevation: 0
                            size_hint_y: None
                            height: dp(70)
                            padding: dp(16), 0, dp(16), 0

                            TextInput:
                                input_filter: "int"
                                on_text: root.limit_pin(self, self.text)
                                halign: "center"
                                hint_text: ""
                                foreground_color: 0.1, 0.1, 0.1, 1
                                background_color: 0, 0, 0, 0
                                cursor_color: 0.13, 0.6, 0.3, 1
                                font_size: dp(26)
                                multiline: False
                                size_hint_y: None
                                height: dp(50)
                                pos_hint: {"center_y": 0.5}
                                padding: [0, dp(10), 0, dp(10)]
                                background_normal: ""
                                background_active: ""

                        # Orange info banner
                        MDCard:
                            md_bg_color: 1, 0.94, 0.82, 1
                            radius: [dp(8)]
                            elevation: 0
                            size_hint_y: None
                            height: dp(64)
                            padding: dp(16), dp(10), dp(16), dp(10)

                            MDLabel:
                                text: "You should have a valid ID with above details."
                                theme_text_color: "Custom"
                                text_color: 0.93, 0.6, 0.13, 1
                                font_size: dp(17)
                                line_height: 1.15
                                valign: "center"

                # ── FINAL FARE CARD ───────────────────────────────
                MDCard:
                    orientation: "horizontal"
                    md_bg_color: 0.965, 0.965, 0.965, 1
                    radius: [dp(12)]
                    elevation: 0
                    line_color: 0.88, 0.88, 0.88, 1
                    line_width: 1
                    size_hint_y: None
                    height: dp(70)
                    padding: dp(20), 0, dp(20), 0
                    spacing: dp(8)

                    MDLabel:
                        text: "Final Fare"
                        theme_text_color: "Custom"
                        text_color: 0.05, 0.05, 0.05, 1
                        bold: True
                        font_size: dp(22)
                        size_hint_x: None
                        width: dp(120)
                        valign: "center"

                    MDIcon:
                        icon: "information"
                        theme_icon_color: "Custom"
                        icon_color: 0.45, 0.45, 0.45, 1
                        font_size: dp(22)
                        size_hint_x: None
                        width: dp(28)
                        pos_hint: {"center_y": 0.5}

                    Widget:

        # ── BOTTOM PAY BAR ────────────────────────────────────────
        MDBoxLayout:
            size_hint_y: None
            height: dp(1)
            md_bg_color: 0.9, 0.9, 0.9, 1

        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(84)
            md_bg_color: 1, 1, 1, 1
            padding: dp(16), dp(12), dp(16), dp(12)
            spacing: dp(14)

            MDBoxLayout:
                orientation: "vertical"
                size_hint_x: None
                width: dp(120)
                spacing: dp(4)

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(20)
                    spacing: dp(4)

                    MDLabel:
                        text: "PAY USING"
                        theme_text_color: "Custom"
                        text_color: 0.5, 0.5, 0.5, 1
                        font_size: dp(13)
                        underline: True
                        size_hint_x: None
                        width: dp(78)
                        valign: "center"

                    MDIcon:
                        icon: "menu-up"
                        theme_icon_color: "Custom"
                        icon_color: 0.4, 0.4, 0.4, 1
                        font_size: dp(18)
                        size_hint_x: None
                        width: dp(20)

                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(28)
                    spacing: dp(8)

                    MDCard:
                        md_bg_color: 0.42, 0.18, 0.62, 1
                        radius: [dp(5)]
                        elevation: 0
                        size_hint: None, None
                        size: dp(24), dp(24)
                        pos_hint: {"center_y": 0.5}

                        AnchorLayout:
                            anchor_x: "center"
                            anchor_y: "center"

                            MDLabel:
                                text: "पे"
                                font_name: "Devanagari"
                                halign: "center"
                                valign: "center"
                                theme_text_color: "Custom"
                                text_color: 1, 1, 1, 1
                                font_size: dp(12)
                                bold: True

                    MDLabel:
                        text: "PhonePe"
                        theme_text_color: "Custom"
                        text_color: 0.1, 0.1, 0.1, 1
                        bold: True
                        font_size: dp(16)
                        valign: "center"

            MDCard:
                md_bg_color: 0.13, 0.6, 0.3, 1
                radius: [dp(10)]
                elevation: 0
                ripple_behavior: True

                MDLabel:
                    text: "Pay"
                    halign: "center"
                    valign: "center"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    bold: True
                    font_size: dp(22)
