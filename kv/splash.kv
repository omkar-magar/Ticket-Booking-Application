#:kivy 2.0

<SplashScreen>:
    # Warm off-white to match the background baked into presplash.png (and the
    # app theme), so the logo blends seamlessly instead of a cream square on white.
    md_bg_color: 0.953, 0.949, 0.941, 1

    MDFloatLayout:
        md_bg_color: 0.953, 0.949, 0.941, 1

        # PMPML brand logo, centered — same asset as the native presplash so the
        # hand-off from the Android splash to this screen looks seamless.
        Image:
            source: "assets/presplash.png"
            mipmap: True
            allow_stretch: True
            keep_ratio: True
            size_hint: None, None
            size: dp(200), dp(200)
            pos_hint: {"center_x": 0.5, "center_y": 0.55}

        MDSpinner:
            size_hint: None, None
            size: dp(36), dp(36)
            pos_hint: {"center_x": 0.5, "center_y": 0.2}
            active: True
            color: 0.17, 0.75, 0.67, 1
