#:kivy 2.0

<DashboardScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.965, 0.953, 0.937, 1

        # ── TOP BAR ──────────────────────────────────────────────
        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(60)
            md_bg_color: 1, 1, 1, 1
            padding: dp(12), dp(8), dp(12), dp(8)

            Image:
                source: "assets/logo_icon.png"
                mipmap: True
                size_hint: None, None
                size: dp(52), dp(52)
                pos_hint: {"center_y": 0.5}
                allow_stretch: True
                keep_ratio: True

            MDBoxLayout:
                size_hint_x: 1

            MDCard:
                md_bg_color: 0, 0, 0, 0
                elevation: 0
                size_hint: None, None
                size: dp(38), dp(38)
                pos_hint: {"center_y": 0.5}
                ripple_behavior: True
                on_release: root.navigate_to("diversion")

                AnchorLayout:
                    anchor_x: "center"
                    anchor_y: "center"

                    Image:
                        source: "assets/notification_icon.png"
                        mipmap: True
                        allow_stretch: True
                        size_hint: None, None
                        size: dp(26), dp(26)

            Widget:
                size_hint_x: None
                width: dp(12)

            MDCard:
                md_bg_color: 0, 0, 0, 0
                elevation: 0
                size_hint: None, None
                size: dp(40), dp(40)
                pos_hint: {"center_y": 0.5}
                ripple_behavior: True
                on_release: root.navigate_to("profile")

                AnchorLayout:
                    anchor_x: "center"
                    anchor_y: "center"

                    Image:
                        source: "assets/profile_icon.png"
                        mipmap: True
                        allow_stretch: True
                        size_hint: None, None
                        size: dp(32), dp(32)

        # Divider
        MDBoxLayout:
            size_hint_y: None
            height: dp(1)
            md_bg_color: 0.91, 0.91, 0.91, 1

        # ── SCROLL BODY ───────────────────────────────────────────
        ScrollView:
            do_scroll_x: False
            bar_width: 0

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                padding: dp(16), dp(16), dp(16), dp(20)
                spacing: dp(16)

                # ── SEARCH BAR ────────────────────────────────────
                MDCard:
                    md_bg_color: 1, 1, 1, 1
                    radius: [dp(16)]
                    elevation: 0
                    size_hint_y: None
                    height: dp(74)
                    padding: dp(10), dp(10), dp(10), dp(10)

                    MDCard:
                        md_bg_color: 0.86, 0.86, 0.86, 1
                        radius: [dp(28)]
                        elevation: 0
                        padding: dp(16), 0, dp(16), 0

                        MDBoxLayout:
                            orientation: "horizontal"
                            spacing: dp(12)

                            Image:
                                source: "assets/search_icon_hd_transparent.png"
                                size_hint: None, None
                                size: dp(24), dp(24)
                                pos_hint: {"center_y": 0.5}
                                mipmap: True
                                allow_stretch: True
                                keep_ratio: True

                            TextInput:
                                hint_text: "कुठे जायचे आहे?"
                                font_name: "Devanagari"
                                hint_text_color: 0.25, 0.25, 0.25, 1
                                foreground_color: 0.1, 0.1, 0.1, 1
                                background_color: 0, 0, 0, 0
                                cursor_color: 0.1, 0.1, 0.1, 1
                                font_size: dp(16)
                                multiline: False
                                size_hint_y: None
                                height: dp(44)
                                pos_hint: {"center_y": 0.5}
                                padding: [0, dp(12), 0, dp(12)]
                                border: (0, 0, 0, 0)
                                background_normal: ""
                                background_active: ""

                # ── LARGE CARDS ───────────────────────────────────
                MDGridLayout:
                    cols: 2
                    spacing: dp(14)
                    adaptive_height: True
                    padding: 0, dp(4), 0, 0

                    # Bus Ticket
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(8)

                        MDCard:
                            md_bg_color: 0.878, 0.937, 0.969, 1
                            radius: [dp(16)]
                            elevation: 0
                            size_hint_y: None
                            height: dp(120)
                            ripple_behavior: True
                            on_release: root.navigate_to("bus_ticket")

                            AnchorLayout:
                                anchor_x: "center"
                                anchor_y: "center"

                                Image:
                                    source: "assets/bus_ticket_icon.png"
                                    mipmap: True
                                    allow_stretch: True
                                    size_hint: None, None
                                    size: dp(50), dp(50)

                        MDLabel:
                            text: "Bus Ticket"
                            halign: "center"
                            valign: "middle"
                            theme_text_color: "Custom"
                            text_color: 0.1, 0.1, 0.1, 1
                            bold: True
                            font_size: dp(15)
                            size_hint_y: None
                            height: dp(24)

                    # Daily Pass
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(8)

                        MDCard:
                            md_bg_color: 0.878, 0.937, 0.969, 1
                            radius: [dp(16)]
                            elevation: 0
                            size_hint_y: None
                            height: dp(120)
                            ripple_behavior: True
                            on_release: root.navigate_to("daily_pass")

                            AnchorLayout:
                                anchor_x: "center"
                                anchor_y: "center"

                                Image:
                                    source: "assets/daily_pass_icon.png"
                                    mipmap: True
                                    allow_stretch: True
                                    size_hint: None, None
                                    size: dp(50), dp(50)

                        MDLabel:
                            text: "Daily Pass"
                            halign: "center"
                            valign: "middle"
                            theme_text_color: "Custom"
                            text_color: 0.1, 0.1, 0.1, 1
                            bold: True
                            font_size: dp(15)
                            size_hint_y: None
                            height: dp(24)

                # ── SMALL CARDS ───────────────────────────────────
                MDGridLayout:
                    cols: 4
                    spacing: dp(10)
                    adaptive_height: True

                    # View Ticket
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(6)

                        MDCard:
                            md_bg_color: 0.878, 0.937, 0.969, 1
                            radius: [dp(14)]
                            elevation: 0
                            size_hint_y: None
                            height: dp(76)
                            ripple_behavior: True
                            on_release: root.navigate_to("view_ticket")

                            AnchorLayout:
                                anchor_x: "center"
                                anchor_y: "center"

                                Image:
                                    source: "assets/view_ticket_icon.png"
                                    mipmap: True
                                    allow_stretch: True
                                    size_hint: None, None
                                    size: dp(34), dp(34)

                        MDLabel:
                            text: "View\nTicket"
                            halign: "center"
                            valign: "top"
                            theme_text_color: "Custom"
                            text_color: 0.1, 0.1, 0.1, 1
                            bold: True
                            font_size: dp(13)
                            line_height: 1.15
                            size_hint_y: None
                            height: dp(34)

                    # View Pass
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(6)

                        MDCard:
                            md_bg_color: 0.878, 0.937, 0.969, 1
                            radius: [dp(14)]
                            elevation: 0
                            size_hint_y: None
                            height: dp(76)
                            ripple_behavior: True
                            on_release: root.navigate_to("view_pass")

                            AnchorLayout:
                                anchor_x: "center"
                                anchor_y: "center"

                                Image:
                                    source: "assets/view_pass_icon.png"
                                    mipmap: True
                                    allow_stretch: True
                                    size_hint: None, None
                                    size: dp(34), dp(34)

                        MDLabel:
                            text: "View\nPass"
                            halign: "center"
                            valign: "top"
                            theme_text_color: "Custom"
                            text_color: 0.1, 0.1, 0.1, 1
                            bold: True
                            font_size: dp(13)
                            line_height: 1.15
                            size_hint_y: None
                            height: dp(34)

                    # Route Timetable
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(6)

                        MDCard:
                            md_bg_color: 0.878, 0.937, 0.969, 1
                            radius: [dp(14)]
                            elevation: 0
                            size_hint_y: None
                            height: dp(76)
                            ripple_behavior: True

                            AnchorLayout:
                                anchor_x: "center"
                                anchor_y: "center"

                                Image:
                                    source: "assets/route_timetable_icon.png"
                                    mipmap: True
                                    allow_stretch: True
                                    size_hint: None, None
                                    size: dp(34), dp(34)

                        MDLabel:
                            text: "Route Ti\nmetable"
                            halign: "center"
                            valign: "top"
                            theme_text_color: "Custom"
                            text_color: 0.1, 0.1, 0.1, 1
                            bold: True
                            font_size: dp(13)
                            line_height: 1.15
                            size_hint_y: None
                            height: dp(34)

                    # Metro Ticket
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(6)

                        MDCard:
                            md_bg_color: 0.878, 0.937, 0.969, 1
                            radius: [dp(14)]
                            elevation: 0
                            size_hint_y: None
                            height: dp(76)
                            ripple_behavior: True

                            AnchorLayout:
                                anchor_x: "center"
                                anchor_y: "center"

                                Image:
                                    source: "assets/metro_icon.png"
                                    mipmap: True
                                    size_hint: None, None
                                    size: dp(60), dp(60)
                                    allow_stretch: True
                                    keep_ratio: True

                        MDLabel:
                            text: "Metro\nTicket"
                            halign: "center"
                            valign: "top"
                            theme_text_color: "Custom"
                            text_color: 0.1, 0.1, 0.1, 1
                            bold: True
                            font_size: dp(13)
                            line_height: 1.15
                            size_hint_y: None
                            height: dp(34)

                # ── NEAR ME SECTION ───────────────────────────────
                MDBoxLayout:
                    orientation: "horizontal"
                    size_hint_y: None
                    height: dp(30)
                    padding: 0, dp(4), 0, 0

                    MDLabel:
                        text: "Near Me"
                        halign: "left"
                        theme_text_color: "Custom"
                        text_color: 0.08, 0.08, 0.08, 1
                        bold: True
                        font_size: dp(20)

                    MDLabel:
                        text: "Show all"
                        halign: "right"
                        theme_text_color: "Custom"
                        text_color: 0.08, 0.08, 0.08, 1
                        font_size: dp(14)
                        underline: True
                        size_hint_x: None
                        width: dp(70)
                        pos_hint: {"center_y": 0.5}

                # Near Me Card
                # upcoming_bus.jpg already contains the full Near Me card
                # (stop name, distance, directions, "No upcoming buses",
                # "See More Buses"), so show it edge-to-edge.
                # Card height = width / image aspect (1016/358 = 2.838) so the
                # image fills the card edge-to-edge with no side gaps.
                MDCard:
                    md_bg_color: 1, 1, 1, 1
                    radius: [dp(14)]
                    elevation: 0
                    size_hint_y: None
                    height: self.width / 2.838
                    padding: 0, 0, 0, 0
                    clip_children: True

                    Image:
                        source: "assets/upcoming_bus.jpg"
                        mipmap: True
                        allow_stretch: True
                        keep_ratio: True
                        size_hint: 1, 1

                # ── NEARBY SECTION ────────────────────────────────
                # The nearby map screenshot already contains the "Nearby"
                # heading + white card, so show it edge-to-edge with no extra
                # label, padding or background of our own.
                # The source PNG is ~2052x1952 (near-square); the card height is
                # sized to that aspect so the map fills the width crisply, and
                # mipmap keeps the downscaled image sharp instead of blurry.
                MDCard:
                    md_bg_color: 1, 1, 1, 1
                    radius: [dp(14)]
                    elevation: 0
                    size_hint_y: None
                    height: self.width * 0.95
                    padding: 0, 0, 0, 0
                    clip_children: True

                    AnchorLayout:
                        anchor_x: "center"
                        anchor_y: "center"

                        MDIcon:
                            icon: "map-marker"
                            theme_icon_color: "Custom"
                            icon_color: 0.8, 0.2, 0.2, 1
                            font_size: dp(40)
                            halign: "center"

                        Image:
                            source: "assets/nearby_map_1080.png"
                            mipmap: True
                            allow_stretch: True
                            keep_ratio: True
                            size_hint: 1, 1

        # ── BOTTOM NAVIGATION ─────────────────────────────────────
        MDBoxLayout:
            size_hint_y: None
            height: dp(1)
            md_bg_color: 0.88, 0.88, 0.88, 1

        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(60)
            md_bg_color: 1, 1, 1, 1
            padding: dp(0), dp(4), dp(0), dp(4)

            MDBoxLayout:
                orientation: "vertical"
                size_hint_x: 1

                AnchorLayout:
                    anchor_x: "center"
                    anchor_y: "center"

                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        adaptive_width: True
                        spacing: dp(2)

                        AnchorLayout:
                            anchor_x: "center"
                            size_hint_y: None
                            height: dp(26)

                            Image:
                                source: "assets/home_icon.png"
                                mipmap: True
                                allow_stretch: True
                                size_hint: None, None
                                size: dp(24), dp(24)

                        MDLabel:
                            text: "Home"
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: 0.1, 0.1, 0.1, 1
                            font_size: dp(11)
                            bold: True
                            size_hint_y: None
                            height: dp(16)

            MDBoxLayout:
                orientation: "vertical"
                size_hint_x: 1

                AnchorLayout:
                    anchor_x: "center"
                    anchor_y: "center"

                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        adaptive_width: True
                        spacing: dp(2)

                        AnchorLayout:
                            anchor_x: "center"
                            size_hint_y: None
                            height: dp(26)

                            Image:
                                source: "assets/buses_icon.png"
                                mipmap: True
                                allow_stretch: True
                                size_hint: None, None
                                size: dp(24), dp(24)

                        MDLabel:
                            text: "Buses"
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: 0.5, 0.5, 0.5, 1
                            font_size: dp(11)
                            size_hint_y: None
                            height: dp(16)

            MDBoxLayout:
                orientation: "vertical"
                size_hint_x: 1

                AnchorLayout:
                    anchor_x: "center"
                    anchor_y: "center"

                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        adaptive_width: True
                        spacing: dp(2)

                        AnchorLayout:
                            anchor_x: "center"
                            size_hint_y: None
                            height: dp(26)

                            Image:
                                source: "assets/help_icon.png"
                                mipmap: True
                                allow_stretch: True
                                size_hint: None, None
                                size: dp(24), dp(24)

                        MDLabel:
                            text: "Help"
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: 0.5, 0.5, 0.5, 1
                            font_size: dp(11)
                            size_hint_y: None
                            height: dp(16)
